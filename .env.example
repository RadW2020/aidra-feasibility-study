# ---- AIDRA Configuration ----
# Copy to .env and fill in real values

# === Database ===
DB_PASSWORD=changeme_strong_password_here
DATABASE_URL=postgresql+asyncpg://aidra:${DB_PASSWORD}@aidra-db:5432/aidra

# === Copernicus Data Space ===
# Register at https://dataspace.copernicus.eu (free)
COPERNICUS_USER=your_email@example.com
COPERNICUS_PASSWORD=your_copernicus_password

# === Grafana ===
GRAFANA_PASSWORD=changeme_grafana_admin
# Set to true only for public demo deployments where anyone may view dashboards.
GRAFANA_ANONYMOUS_ENABLED=false
GRAFANA_ANONYMOUS_ORG_NAME=Main Org.

# === Directories ===
MODELS_DIR=/app/models
IMAGES_DIR=/data/images

# === Pipeline Defaults ===
DEFAULT_ZONE=gibraltar
DEFAULT_MODEL=yolov8n-sar
DEFAULT_PROFILE=ground
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45

# === CFAR Defaults ===
CFAR_GUARD_SIZE=3
CFAR_TRAINING_SIZE=15
CFAR_PFA=1e-5

# === Tile Defaults ===
TILE_SIZE=640
TILE_OVERLAP=64

# === Tip & Cue ===
TIPCUE_ENABLED=true
TIPCUE_MIN_CONFIDENCE=0.7
TIPCUE_MIN_DETECTIONS=2
TIPCUE_COOLDOWN_MINUTES=60

# === Scheduler ===
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_HOURS=6

# === Observability ===
PROMETHEUS_ENABLED=true
LOKI_URL=http://aidra-loki:3100
LOG_LEVEL=INFO

# === Limits ===
MAX_IMAGE_SIZE_GB=2.0
MAX_CONCURRENT_PIPELINES=1
PIPELINE_TIMEOUT_SECONDS=600
