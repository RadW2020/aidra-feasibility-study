{
  "uid": "aidra-compression-bench",
  "title": "AIDRA — Compression Benchmarks",
  "description": "Comparison of model variants across size, latency, RAM and accuracy.",
  "tags": ["aidra", "compression", "benchmark"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "refresh": "1m",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["30s", "1m", "5m", "15m"]
  },
  "templating": {
    "list": [
      {
        "name": "profile",
        "type": "query",
        "label": "Constraint Profile",
        "datasource": {
          "type": "postgres",
          "uid": "PostgreSQL"
        },
        "query": "SELECT DISTINCT constraint_profile FROM execution_log ORDER BY constraint_profile",
        "includeAll": false,
        "current": {
          "text": "ground",
          "value": "ground"
        },
        "refresh": 1,
        "sort": 1,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Model Size per Variant (MB)",
      "description": "Model file size per compression variant.",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "rawSql": "SELECT\n    model_name || ' ' || model_version AS variant,\n    model_size_mb\nFROM execution_log\nWHERE constraint_profile = '$profile'\n    AND status = 'success'\nGROUP BY model_name, model_version, model_size_mb\nORDER BY model_size_mb DESC",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "axisCenteredZero": false
          },
          "color": { "mode": "palette-classic" },
          "unit": "decmbytes"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "always",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 2,
      "title": "Total Inference Time per Variant",
      "description": "Total wall-clock time to process the full scene (all tiles) per model variant. Grafana auto-scales the ms unit to minutes for large values — both variants take tens of minutes because this is full-scene time, not per-tile. What matters here is the relative ratio: INT8 should be ~1.5x faster than FP32.",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "rawSql": "SELECT\n    model_name || ' ' || model_version AS variant,\n    ROUND(AVG(inference_ms)::numeric, 1) AS avg_inference_ms\nFROM execution_log\nWHERE constraint_profile = '$profile'\n    AND status = 'success'\nGROUP BY model_name, model_version\nORDER BY avg_inference_ms DESC",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1
          },
          "color": { "mode": "palette-classic" },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "always",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 3,
      "title": "Confidence vs Latency Trade-off",
      "description": "Accuracy-speed trade-off per model variant. Lower latency + higher confidence = better. The table is sorted by latency so the fastest variant is always at the top — use this alongside the size panel to judge whether compression cost is worth the gain.",
      "type": "table",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "rawSql": "SELECT\n    model_name || ' ' || model_version AS variant,\n    ROUND(AVG(inference_ms)::numeric, 1) AS avg_latency_ms,\n    ROUND(AVG(avg_confidence)::numeric, 3) AS avg_confidence,\n    ROUND(model_size_mb::numeric, 1) AS size_mb\nFROM execution_log\nWHERE constraint_profile = '$profile'\n    AND status = 'success'\n    AND avg_confidence IS NOT NULL\nGROUP BY model_name, model_version, model_size_mb\nORDER BY avg_latency_ms",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "avg_latency_ms" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "displayName", "value": "Total Time" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "variant" },
            "properties": [
              { "id": "custom.width", "value": 280 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "avg_confidence" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "displayName", "value": "Avg Confidence" },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "yellow", "value": null },
                    { "color": "green", "value": 0.5 }
                  ]
                }
              },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "size_mb" },
            "properties": [
              { "id": "unit", "value": "decmbytes" },
              { "id": "displayName", "value": "Size (MB)" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false },
        "sortBy": [{ "displayName": "Avg Latency", "desc": false }]
      }
    },
    {
      "id": 4,
      "title": "Peak RAM per Variant (MB)",
      "description": "Peak RSS during inference per model variant. NOT a hard limit — measured after removing RLIMIT_AS enforcement (which killed the host process). Budget breaches are recorded in execution_log.notes. Variation between variants is real: INT8 loads a smaller weight blob but ONNX Runtime allocates additional buffers.",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "rawSql": "SELECT\n    model_name || ' ' || model_version AS variant,\n    ROUND(AVG(peak_ram_mb)::numeric, 1) AS avg_peak_ram_mb\nFROM execution_log\nWHERE constraint_profile = '$profile'\n    AND status = 'success'\nGROUP BY model_name, model_version\nORDER BY avg_peak_ram_mb DESC",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1
          },
          "color": { "mode": "palette-classic" },
          "unit": "decmbytes"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 5,
      "title": "Benchmark Comparison Table",
      "description": "Full comparison table: model × size × latency × RAM × accuracy.",
      "type": "table",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "PostgreSQL"
          },
          "rawSql": "SELECT\n    model_name,\n    model_version,\n    compression_technique,\n    model_size_mb,\n    ROUND(AVG(inference_ms)::numeric, 1) AS avg_inference_ms,\n    ROUND(AVG(peak_ram_mb)::numeric, 1) AS avg_peak_ram_mb,\n    ROUND(AVG(num_detections)::numeric, 1) AS avg_detections,\n    ROUND(AVG(avg_confidence)::numeric, 3) AS avg_confidence,\n    COUNT(*) AS num_runs\nFROM execution_log\nWHERE constraint_profile = '$profile'\n    AND status = 'success'\nGROUP BY model_name, model_version, compression_technique, model_size_mb\nORDER BY model_size_mb",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "model_size_mb" },
            "properties": [
              { "id": "unit", "value": "decmbytes" },
              { "id": "displayName", "value": "Size (MB)" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "avg_inference_ms" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "displayName", "value": "Avg Total Time" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "avg_peak_ram_mb" },
            "properties": [
              { "id": "unit", "value": "decmbytes" },
              { "id": "displayName", "value": "Avg Peak RAM (MB)" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "avg_confidence" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "displayName", "value": "Avg Confidence" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "compression_technique" },
            "properties": [
              { "id": "displayName", "value": "Compression" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "model_name" },
            "properties": [
              { "id": "custom.width", "value": 180 },
              { "id": "displayName", "value": "Model" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "model_version" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "displayName", "value": "Version" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "countRows": false
        },
        "sortBy": [
          { "displayName": "Size (MB)", "desc": false }
        ]
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
