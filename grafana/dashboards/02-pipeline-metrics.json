{
  "uid": "aidra-pipeline-metrics",
  "title": "AIDRA — Pipeline Metrics",
  "description": "Pipeline performance metrics: run rate, inference duration, RAM, CPU, errors and logs.",
  "tags": ["aidra", "pipeline", "metrics", "prometheus"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "refresh": "15s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "15s", "30s", "1m", "5m"]
  },
  "templating": {
    "list": [
      {
        "name": "profile",
        "type": "query",
        "label": "Profile",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(aidra_pipeline_runs_total, profile)",
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true
      },
      {
        "name": "model_variant",
        "type": "query",
        "label": "Model Variant",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(aidra_pipeline_runs_total, model_variant)",
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Pipeline Run Rate (runs/hour)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum(rate(aidra_pipeline_runs_total{profile=~\"$profile\", model_variant=~\"$model_variant\"}[1h])) by (status)",
          "legendFormat": "{{status}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "mode": "none" },
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "title": "Inference Duration (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "histogram_quantile(0.50, sum(rate(aidra_inference_duration_seconds_bucket{profile=~\"$profile\", model_variant=~\"$model_variant\"}[5m])) by (le))",
          "legendFormat": "P50",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(aidra_inference_duration_seconds_bucket{profile=~\"$profile\", model_variant=~\"$model_variant\"}[5m])) by (le))",
          "legendFormat": "P95",
          "editorMode": "code"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(aidra_inference_duration_seconds_bucket{profile=~\"$profile\", model_variant=~\"$model_variant\"}[5m])) by (le))",
          "legendFormat": "P99",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 3,
      "title": "Peak RAM (MB)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "max(aidra_peak_ram_mb{profile=~\"$profile\", model_variant=~\"$model_variant\"})",
          "legendFormat": "Peak RAM",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 512 },
              { "color": "orange", "value": 1024 },
              { "color": "red", "value": 2048 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "decmbytes",
          "min": 0,
          "max": 4096
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "title": "CPU Usage (% of 4 OCPU)",
      "description": "Process CPU usage during the last inference, expressed as a percentage of the 4-OCPU OCI ARM A1 budget (Linux convention: 100% = one core saturated, 400% = all four cores saturated).",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "max(aidra_cpu_usage_percent{profile=~\"$profile\", model_variant=~\"$model_variant\"})",
          "legendFormat": "CPU Usage",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "orange", "value": 320 },
              { "color": "red", "value": 380 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 400
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      }
    },
    {
      "id": 5,
      "title": "Detections per Execution",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 6 },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "sum(rate(aidra_detections_total{profile=~\"$profile\"}[5m])) by (source)",
          "legendFormat": "{{source}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "title": "Error Rate",
      "description": "Share of execution_log rows that finished with status != 'success'. Sourced from Postgres (the previous Prometheus rate query reset on every redeploy and inflated to 100% with a single failed run).",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "PostgreSQL" },
          "rawSql": "SELECT COALESCE(COUNT(*) FILTER (WHERE status != 'success')::float / NULLIF(COUNT(*), 0), 0) AS error_rate FROM execution_log",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "orientation": "auto"
      }
    },
    {
      "id": 7,
      "title": "Pipeline Runs Total",
      "description": "Total runs recorded in execution_log (success / total). Sourced from Postgres so the value persists across app restarts; the equivalent Prometheus counter resets on every redeploy.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 14, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "PostgreSQL" },
          "rawSql": "SELECT COUNT(*) FILTER (WHERE status = 'success')::int AS \"success\", COUNT(*)::int AS \"total\" FROM execution_log",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      }
    },
    {
      "id": 8,
      "title": "Model Size (MB)",
      "description": "Disk size of each registered model variant. Sourced from models_registry (the equivalent Prometheus gauge aidra_model_size_mb is defined but never populated, so it always reads 0).",
      "type": "bargauge",
      "gridPos": { "x": 4, "y": 14, "w": 8, "h": 6 },
      "datasource": { "type": "postgres", "uid": "PostgreSQL" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "PostgreSQL" },
          "rawSql": "SELECT (name || ':' || version) AS model_variant, size_mb FROM models_registry ORDER BY size_mb DESC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "decmbytes"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^size_mb$/", "values": true },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10,
        "namePlacement": "auto",
        "valueMode": "color"
      }
    },
    {
      "id": 9,
      "title": "Recent Pipeline Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 8 },
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "{container=\"aidra-app\"} |= \"pipeline\"",
          "editorMode": "code"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
