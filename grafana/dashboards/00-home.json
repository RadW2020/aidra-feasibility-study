        "content": "<div style='padding:8px 4px;border-bottom:1px solid #2b3645'>\n  <span style='font-size:11px;color:#7ea0c4;letter-spacing:3px;font-weight:700'>SECTION 3 / 3</span>\n  <h2 style='margin:2px 0 0;font-size:22px;color:#f3f6fb;font-weight:700'>Space hardware simulation</h2>\n  <div style='font-size:13px;color:#9ec1ff;margin-top:2px'>The story for the spacecraft systems engineer · downlink savings, latency, resilience</div>\n</div>"
      }
