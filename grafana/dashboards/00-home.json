      "transparent": true,
      "gridPos": { "x": 0, "y": 26, "w": 8, "h": 6 },
      "options": {
        "mode": "html",
        "content": "<a href='/d/aidra-compression-bench' style='text-decoration:none;color:inherit;display:block;height:100%'>\n  <div style='height:100%;padding:18px 20px;border-radius:12px;background:#111922;border:1px solid #2b3645;transition:all .15s ease'>\n    <div style='display:flex;justify-content:space-between;align-items:start'>\n      <div style='font-size:11px;color:#c293e0;letter-spacing:2px;font-weight:700'>03 · COMPRESSION BENCH</div>\n      <div style='font-size:13px;color:#84baef'>open →</div>\n    </div>\n    <div style='font-size:18px;font-weight:700;color:#f3f6fb;margin:8px 0 6px'>Quantization, pruning, KD</div>\n    <div style='font-size:13px;line-height:1.5;color:#aebed1'>Every variant evaluated as a {baseline, variant, profile} triplet. Trade-offs in mAP, Pd / FAR, latency p50/p95, RAM and disk size — measured, not estimated.</div>\n  </div>\n</a>"
      }
    },
    {
      "id": 32,
      "type": "text",
      "title": "",
      "transparent": true,
      "gridPos": { "x": 8, "y": 26, "w": 8, "h": 6 },
      "options": {
        "mode": "html",
        "content": "<a href='/d/aidra-constraint-profiles' style='text-decoration:none;color:inherit;display:block;height:100%'>\n  <div style='height:100%;padding:18px 20px;border-radius:12px;background:#111922;border:1px solid #2b3645;transition:all .15s ease'>\n    <div style='display:flex;justify-content:space-between;align-items:start'>\n      <div style='font-size:11px;color:#c293e0;letter-spacing:2px;font-weight:700'>04 · CONSTRAINT PROFILES</div>\n      <div style='font-size:13px;color:#84baef'>open →</div>\n    </div>\n    <div style='font-size:18px;font-weight:700;color:#f3f6fb;margin:8px 0 6px'>Five hardware budgets, one model</div>\n    <div style='font-size:13px;line-height:1.5;color:#aebed1'>From <i>ground</i> (4 OCPU / 24 GB) down to <i>sat-extreme</i> (0.25 OCPU / 512 MB). The same scene, the same model, four orders of magnitude of compute — and where the pipeline starts to break.</div>\n  </div>\n</a>"
      }
    },
    {
      "id": 33,
      "type": "text",
      "title": "",
      "transparent": true,
      "gridPos": { "x": 16, "y": 26, "w": 8, "h": 6 },
      "options": {
        "mode": "html",
        "content": "<a href='/d/aidra-traceability' style='text-decoration:none;color:inherit;display:block;height:100%'>\n  <div style='height:100%;padding:18px 20px;border-radius:12px;background:#111922;border:1px solid #2b3645;transition:all .15s ease'>\n    <div style='display:flex;justify-content:space-between;align-items:start'>\n      <div style='font-size:11px;color:#c293e0;letter-spacing:2px;font-weight:700'>05 · TRACEABILITY</div>\n      <div style='font-size:13px;color:#84baef'>open →</div>\n    </div>\n    <div style='font-size:18px;font-weight:700;color:#f3f6fb;margin:8px 0 6px'>Provable lineage, every artifact</div>\n    <div style='font-size:13px;line-height:1.5;color:#aebed1'>Image hash → model hash → input-params hash → output hash, plus the git commit SHA — all persisted at run start, not just on success. The backbone of the D3 evidence bundle.</div>\n  </div>\n</a>"
      }
    },

