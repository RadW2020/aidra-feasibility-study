      "gridPos": { "x": 16, "y": 34, "w": 8, "h": 6 },
      "options": {
        "mode": "html",
        "content": "<a href='/d/aidra-orbital-resilience' style='text-decoration:none;color:inherit;display:block;height:100%'>\n  <div style='height:100%;padding:18px 20px;border-radius:12px;background:#111922;border:1px solid #2b3645;transition:all .15s ease'>\n    <div style='display:flex;justify-content:space-between;align-items:start'>\n      <div style='font-size:11px;color:#f3d76b;letter-spacing:2px;font-weight:700'>08 · ORBITAL RESILIENCE</div>\n      <div style='font-size:13px;color:#84baef'>open →</div>\n    </div>\n    <div style='font-size:18px;font-weight:700;color:#f3f6fb;margin:8px 0 6px'>What breaks first when space gets ugly</div>\n    <div style='font-size:13px;line-height:1.5;color:#aebed1'>Bit-flip injection, model drift detection, battery budget, autonomous mode decisions. The pipeline measured against the failure modes that actually happen in LEO.</div>\n  </div>\n</a>"
      }
    },

    {
      "id": 99,
      "type": "text",
      "title": "",
      "transparent": true,
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 5 },
      "options": {
        "mode": "html",
        "content": "<div style='padding:18px 22px;border-radius:12px;background:#0e1620;border:1px solid #2b3645;display:grid;grid-template-columns:2fr 1fr 1fr;gap:24px'>\n  <div>\n    <div style='font-size:11px;color:#7ea0c4;letter-spacing:2px;font-weight:700;margin-bottom:8px'>STACK</div>\n    <div style='font-size:13px;line-height:1.7;color:#dde6f3'>\n      Python 3.11 · FastAPI · PyTorch / Ultralytics YOLOv8 · ONNX Runtime ·\n      rasterio / GDAL · scikit-learn · APScheduler<br/>\n      PostgreSQL 16 + PostGIS 3.6 · Prometheus · Loki · Grafana 11 · Docker Compose · Coolify on OCI ARM A1\n    </div>\n  </div>\n  <div>\n    <div style='font-size:11px;color:#7ea0c4;letter-spacing:2px;font-weight:700;margin-bottom:8px'>DATA</div>\n    <div style='font-size:13px;line-height:1.7;color:#dde6f3'>\n      Sentinel-1 GRD via Copernicus Data Space (EU)<br/>\n      Reference datasets: xView3-SAR, HRSID, OpenSARShip<br/>\n      All storage and compute kept inside the EU\n    </div>\n  </div>\n  <div>\n    <div style='font-size:11px;color:#7ea0c4;letter-spacing:2px;font-weight:700;margin-bottom:8px'>BUILT BY</div>\n    <div style='font-size:13px;line-height:1.7;color:#dde6f3'>\n      Independent feasibility study<br/>\n      <a href='https://github.com/RadW2020/aidra-feasibility-study' style='color:#84baef;text-decoration:none' target='_blank'>github.com/RadW2020/aidra-feasibility-study →</a><br/>\n      <span style='color:#7ea0c4;font-size:12px'>MIT License · No personal data processed</span>\n    </div>\n  </div>\n</div>"
      }
    }
  ]
}
