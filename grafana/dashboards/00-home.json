        "mode": "html",
        "content": "<div style='padding:8px 4px;border-bottom:1px solid #2b3645'>\n  <span style='font-size:11px;color:#7ea0c4;letter-spacing:3px;font-weight:700'>SECTION 1 / 3</span>\n  <h2 style='margin:2px 0 0;font-size:22px;color:#f3f6fb;font-weight:700'>Mission operations</h2>\n  <div style='font-size:13px;color:#9ec1ff;margin-top:2px'>What the operator sees · live SAR detections, pipeline health, autonomous re-tasking</div>\n</div>"
      }
